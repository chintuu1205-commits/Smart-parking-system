// === Setup awal ===
void setup() {
pinMode(TRIG_IN, OUTPUT);
pinMode(ECHO_IN, INPUT);
pinMode(TRIG_OUT, OUTPUT);
pinMode(ECHO_OUT, INPUT);
pinMode(LED_PIN, OUTPUT); I
gateIn.attach(9);
gateOut.attach(10);
gateIn.write(0);
gateOut.write(0);
oled.begin();
oled.clearBuffer();
oled.setFont(u8g2_font_6x10_tr);
oled.drawStr(0, 30, "Smart Parking Init...");
oled.sendBuffer();
delay(1500);
}
// ===Loop utama ===
void loop() {
long distIn readDistanceCM (TRIG_IN, ECHO_IN);
long distOut = readDistanceCM (TRIG_OUT, ECHO_OUT);
//===Mobil Masuk ===
if (distIn <DIST_GATE && availableSlots > 0 && !gateInOpen) {
gateIn.write(90);
gateInOpen true;
}
if (gateInOpen && distIn > DIST_PASS) {
gateIn.write(0);
gateInOpen false;
if (availableSlots > 0) availableSlots--;
}
// ===Mobil Keluar ===
if (distOut <DIST_GATE && availableSlots < TOTAL_SLOTS && !gateOutOpen)
gateOut.write(90);
gateOutOpen = true;
}
if (gateOutOpen && distOut > DIST_PASS) {
gateOut.write(0);
gateOutOpen = false;
if (availableSlots <TOTAL_SLOTS) availableSlots++;
}
// === Update OLED ===
if (millis() lastDisplay >500) {
drawDisplay();
lastDisplay millis();
}
delay(100);
}
