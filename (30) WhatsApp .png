<li dir="auto" class="x1g0dm76 x1jieuv1 xo7wnuk x1gznph8 x1rkpvhg xlu7um4 xm78dhd x1r4uxqn"><span class="_ao3e _aupe copyable-text" data-testid="selectable-text" data-pre-plain-text="- ">Servo motor-based gate automation (entry and exit)  </span></li>
<li dir="auto" class="x1g0dm76 x1jieuv1 xo7wnuk x1gznph8 x1rkpvhg xlu7um4 xm78dhd x1r4uxqn"><span class="_ao3e _aupe copyable-text" data-testid="selectable-text" data-pre-plain-text="- ">Real-time parking slot status display using OLED and LEDs  </span></li>
